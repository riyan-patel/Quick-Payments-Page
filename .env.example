# Copy to .env.local and fill in values. Never commit real secrets.

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# Client key: legacy JWT "anon" OR new publishable key (sb_publishable_...)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only: legacy JWT "service_role" OR new secret key (sb_secret_...) — never expose to browser
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (Dashboard → Developers → API keys) — use test keys locally
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...

# Resend (https://resend.com)
RESEND_API_KEY=re_...
# Test: use onboarding@resend.dev — Resend often only delivers to YOUR Resend signup email.
# Production: verify a domain in Resend, then e.g. RESEND_FROM_EMAIL=Receipts <receipts@yourdomain.com>
# Avoid extra quotes; display name is optional: Quick Payment Pages <onboarding@resend.dev>
RESEND_FROM_EMAIL=onboarding@resend.dev

# Used for iframe snippets, QR targets, and absolute links in emails
# Example: https://your-app.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# OpenAI — “Ask a question (AI)” on Reports (generates SQL, then a summary)
# OPENAI_API_KEY=sk-...
# “Ask a question (AI)” on Reports uses the Supabase API + your session (no DATABASE_URL or pooler).
# OPENAI_REPORTS_MODEL=gpt-4o-mini
